# .ralphrc.devin - Ralph project configuration (Devin CLI)
# Generated by: ralph-devin-enable
# Documentation: https://github.com/frankbria/ralph-claude-code

# Project identification
PROJECT_NAME="bookshelf"
PROJECT_TYPE="generic"

# Engine selection
RALPH_ENGINE="devin"

# Loop settings
MAX_CALLS_PER_HOUR=100
DEVIN_TIMEOUT_MINUTES=30

# Devin-specific settings
# DEVIN_MAX_ACU=             # Maximum ACU limit per session
# DEVIN_API_TOKEN=           # Set via 'devin configure' or environment variable

# Session management
DEVIN_USE_CONTINUE=true
DEVIN_SESSION_EXPIRY_HOURS=24

# Polling configuration
DEVIN_POLL_INTERVAL=15
DEVIN_MAX_POLL_ATTEMPTS=240

# Task sources
TASK_SOURCES="local"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# Circuit breaker thresholds
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
